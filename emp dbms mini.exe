import javax.swing.*;
import java.awt.*;
import java.awt.event.*;
import java.sql.*;

public class EmployeeManagementGUI extends JFrame {

    // GUI Components
    private JTextField txtId, txtName, txtDept, txtSalary;
    private JTextArea outputArea;
    private JButton btnInsert, btnView, btnUpdate, btnDelete, btnClear;

    // Database Connection
    private Connection con;

    public EmployeeManagementGUI() {
        setTitle("Employee Management System");
        setSize(600, 500);
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setLayout(null);
        setLocationRelativeTo(null); // Center the window

        JLabel lblTitle = new JLabel("Employee Management System", JLabel.CENTER);
        lblTitle.setFont(new Font("Arial", Font.BOLD, 20));
        lblTitle.setBounds(100, 10, 400, 30);
        add(lblTitle);

        // Labels and TextFields
        JLabel lblId = new JLabel("Employee ID:");
        lblId.setBounds(50, 70, 100, 25);
        add(lblId);
        txtId = new JTextField();
        txtId.setBounds(160, 70, 150, 25);
        add(txtId);

        JLabel lblName = new JLabel("Name:");
        lblName.setBounds(50, 110, 100, 25);
        add(lblName);
        txtName = new JTextField();
        txtName.setBounds(160, 110, 150, 25);
        add(txtName);

        JLabel lblDept = new JLabel("Department:");
        lblDept.setBounds(50, 150, 100, 25);
        add(lblDept);
        txtDept = new JTextField();
        txtDept.setBounds(160, 150, 150, 25);
        add(txtDept);

        JLabel lblSalary = new JLabel("Salary:");
        lblSalary.setBounds(50, 190, 100, 25);
        add(lblSalary);
        txtSalary = new JTextField();
        txtSalary.setBounds(160, 190, 150, 25);
        add(txtSalary);

        // Buttons
        btnInsert = new JButton("Insert");
        btnInsert.setBounds(350, 70, 100, 30);
        add(btnInsert);

        btnView = new JButton("View");
        btnView.setBounds(350, 110, 100, 30);
        add(btnView);

        btnUpdate = new JButton("Update");
        btnUpdate.setBounds(350, 150, 100, 30);
        add(btnUpdate);

        btnDelete = new JButton("Delete");
        btnDelete.setBounds(350, 190, 100, 30);
        add(btnDelete);

        btnClear = new JButton("Clear");
        btnClear.setBounds(350, 230, 100, 30);
        add(btnClear);

        // Output Area
        outputArea = new JTextArea();
        outputArea.setEditable(false);
        JScrollPane scrollPane = new JScrollPane(outputArea);
        scrollPane.setBounds(50, 280, 480, 150);
        add(scrollPane);

        // Connect to MySQL Database
        connectDatabase();

        // Button Actions
        btnInsert.addActionListener(e -> insertEmployee());
        btnView.addActionListener(e -> viewEmployees());
        btnUpdate.addActionListener(e -> updateEmployee());
        btnDelete.addActionListener(e -> deleteEmployee());
        btnClear.addActionListener(e -> clearFields());
    }

    private void connectDatabase() {
        try {
            Class.forName("com.mysql.cj.jdbc.Driver");
            con = DriverManager.getConnection(
                "jdbc:mysql://localhost:3306/db1?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC",
                "root",    // your MySQL username
                "189225"   // your MySQL password
            );
            outputArea.setText("✅ Connected to MySQL Database successfully!\n");
        } catch (Exception e) {
            JOptionPane.showMessageDialog(this, "Database Connection Failed:\n" + e.getMessage());
        }
    }

    private void insertEmployee() {
        try {
            String sql = "INSERT INTO employee (emp_id, name, department, salary) VALUES (?, ?, ?, ?)";
            PreparedStatement ps = con.prepareStatement(sql);
            ps.setInt(1, Integer.parseInt(txtId.getText()));
            ps.setString(2, txtName.getText());
            ps.setString(3, txtDept.getText());
            ps.setDouble(4, Double.parseDouble(txtSalary.getText()));
            ps.executeUpdate();
            outputArea.append("✅ Employee inserted successfully!\n");
            ps.close();
        } catch (Exception e) {
            outputArea.append("❌ Error inserting employee: " + e.getMessage() + "\n");
        }
    }

    private void viewEmployees() {
        try {
            String sql = "SELECT * FROM employee";
            Statement stmt = con.createStatement();
            ResultSet rs = stmt.executeQuery(sql);
            outputArea.setText("📋 Employee Records:\n------------------------------------------\n");
            while (rs.next()) {
                outputArea.append(
                    "ID: " + rs.getInt("emp_id") +
                    " | Name: " + rs.getString("name") +
                    " | Dept: " + rs.getString("department") +
                    " | Salary: " + rs.getDouble("salary") + "\n"
                );
            }
            rs.close();
        } catch (Exception e) {
            outputArea.append("❌ Error fetching employees: " + e.getMessage() + "\n");
        }
    }

    private void updateEmployee() {
        try {
            String sql = "UPDATE employee SET salary=? WHERE emp_id=?";
            PreparedStatement ps = con.prepareStatement(sql);
            ps.setDouble(1, Double.parseDouble(txtSalary.getText()));
            ps.setInt(2, Integer.parseInt(txtId.getText()));
            int rows = ps.executeUpdate();
            if (rows > 0)
                outputArea.append("✅ Employee salary updated successfully!\n");
            else
                outputArea.append("⚠️ Employee not found!\n");
            ps.close();
        } catch (Exception e) {
            outputArea.append("❌ Error updating employee: " + e.getMessage() + "\n");
        }
    }

    private void deleteEmployee() {
        try {
            String sql = "DELETE FROM employee WHERE emp_id=?";
            PreparedStatement ps = con.prepareStatement(sql);
            ps.setInt(1, Integer.parseInt(txtId.getText()));
            int rows = ps.executeUpdate();
            if (rows > 0)
                outputArea.append("✅ Employee deleted successfully!\n");
            else
                outputArea.append("⚠️ Employee not found!\n");
            ps.close();
        } catch (Exception e) {
            outputArea.append("❌ Error deleting employee: " + e.getMessage() + "\n");
        }
    }

    private void clearFields() {
        txtId.setText("");
        txtName.setText("");
        txtDept.setText("");
        txtSalary.setText("");
        outputArea.setText("");
    }

    public static void main(String[] args) {
        SwingUtilities.invokeLater(() -> {
            new EmployeeManagementGUI().setVisible(true);
        });
    }
}

